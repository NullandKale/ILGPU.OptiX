<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ILGPU" Version="1.5.3" />
    <PackageReference Include="ILGPU.Algorithms" Version="1.5.3" />
    <PackageReference Include="OpenTK" Version="4.8.2" />
    <PackageReference Include="StbImageSharp" Version="2.30.15" />
    <PackageReference Include="ImGui.NET" Version="1.91.6.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Src\ILGPU.OptiX\ILGPU.OptiX.csproj" />
    <!-- Build-only dependency: patches this project's own output exe after every
         build, so ReferenceOutputAssembly is off (we don't want its assembly on
         our reference list, just its build output on disk before PatchGpuExports
         runs). -->
    <ProjectReference Include="..\..\Tools\GpuExportPatcher\GpuExportPatcher.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- True zero-copy CUDA-GL interop (see Rendering/CudaGlInterop.cs) requires the
       OpenGL context and the CUDA device to be on the same physical GPU. On
       hybrid-graphics laptops, Windows may otherwise route the OpenGL context to
       the integrated GPU while CUDA/OptiX use the discrete NVIDIA one, making
       cuGraphicsGLRegisterBuffer fail. NvOptimusEnablement/
       AmdPowerXpressRequestHighPerformance are the standard driver hints that
       route a process to the discrete GPU automatically - C++ apps embed them via
       __declspec(dllexport), but modern .NET's generated apphost has no
       source-level way to add PE exports (see dotnet/runtime#60422), so this
       patches them into the built exe after the fact instead. -->
  <Target Name="PatchGpuExports" AfterTargets="Build">
    <!-- $(TargetPath) is the managed assembly (Sample13.dll) - the apphost native
         launcher the OS actually starts is always "<AssemblyName>.exe" next to it. -->
    <Exec Command="dotnet &quot;$(MSBuildThisFileDirectory)..\..\Tools\GpuExportPatcher\bin\$(Configuration)\net8.0\GpuExportPatcher.dll&quot; &quot;$(TargetDir)$(TargetName).exe&quot;" />
  </Target>

  <ItemGroup>
    <!-- cow.obj/stanford-bunny.obj/teapot.obj/xyzrgb_dragon.obj + Sponza, same asset
         set Sample13 bundles (see Sample13.csproj) - museum's video-textured scenes
         are deferred, so no museum assets here yet. -->
    <None Include="..\Models\meshes\**\*.*">
      <Link>models\meshes\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\Models\sponza\sponza.obj">
      <Link>models\sponza\sponza.obj</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\Models\sponza\sponza.mtl">
      <Link>models\sponza\sponza.mtl</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\Models\sponza\textures\**\*.*">
      <Link>models\sponza\textures\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
