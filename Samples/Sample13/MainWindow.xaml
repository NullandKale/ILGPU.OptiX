<Window x:Class="Sample13.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sample13"
        mc:Ignorable="d"
        Title="ILGPU.Optix Sample13" Height="800" Width="1200" ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="PanelLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="PanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="Background" Value="#003D3D3D"/>
            <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Image x:Name="Frame" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>

        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="10" Padding="12"
                Background="#80000000">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="750">
                <StackPanel Orientation="Vertical" Width="320">
                    <!-- Scene Selection Section -->
                    <TextBlock Style="{StaticResource PanelHeaderStyle}" Text="SCENE"/>
                    <TextBlock x:Name="SceneNameText" Style="{StaticResource PanelLabelStyle}" Text="Scene" Margin="0,4,0,6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <Button x:Name="PrevSceneBtn" Style="{StaticResource ControlButtonStyle}" Content="&lt;" Click="PrevSceneBtn_Click" Width="40"/>
                        <TextBlock Text="" Width="10"/>
                        <Button x:Name="NextSceneBtn" Style="{StaticResource ControlButtonStyle}" Content="&gt;" Click="NextSceneBtn_Click" Width="40"/>
                    </StackPanel>

                    <!-- Render Settings Section -->
                    <TextBlock Style="{StaticResource PanelHeaderStyle}" Text="RENDER SETTINGS" Margin="0,12,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Mirror:" VerticalAlignment="Center" Width="80"/>
                        <Button x:Name="MirrorDecBtn" Style="{StaticResource ControlButtonStyle}" Content="-" Click="MirrorDecBtn_Click"/>
                        <TextBlock x:Name="MirrorCountText" Style="{StaticResource PanelLabelStyle}" Text="1" Width="40" TextAlignment="Center" VerticalAlignment="Center"/>
                        <Button x:Name="MirrorIncBtn" Style="{StaticResource ControlButtonStyle}" Content="+" Click="MirrorIncBtn_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Refraction:" VerticalAlignment="Center" Width="80"/>
                        <Button x:Name="RefractionDecBtn" Style="{StaticResource ControlButtonStyle}" Content="-" Click="RefractionDecBtn_Click"/>
                        <TextBlock x:Name="RefractionCountText" Style="{StaticResource PanelLabelStyle}" Text="1" Width="40" TextAlignment="Center" VerticalAlignment="Center"/>
                        <Button x:Name="RefractionIncBtn" Style="{StaticResource ControlButtonStyle}" Content="+" Click="RefractionIncBtn_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Diffuse:" VerticalAlignment="Center" Width="80"/>
                        <Button x:Name="DiffuseDecBtn" Style="{StaticResource ControlButtonStyle}" Content="-" Click="DiffuseDecBtn_Click"/>
                        <TextBlock x:Name="DiffuseCountText" Style="{StaticResource PanelLabelStyle}" Text="1" Width="40" TextAlignment="Center" VerticalAlignment="Center"/>
                        <Button x:Name="DiffuseIncBtn" Style="{StaticResource ControlButtonStyle}" Content="+" Click="DiffuseIncBtn_Click"/>
                    </StackPanel>

                    <!-- Options Section -->
                    <TextBlock Style="{StaticResource PanelHeaderStyle}" Text="OPTIONS" Margin="0,12,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button x:Name="DenoiserBtn" Style="{StaticResource ControlButtonStyle}" Content="Denoise" Click="DenoiserBtn_Click" Width="Auto" Padding="6,4"/>
                        <TextBlock x:Name="DenoiserStatusText" Style="{StaticResource PanelLabelStyle}" Text="ON" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button x:Name="AccumulateBtn" Style="{StaticResource ControlButtonStyle}" Content="Accumulate" Click="AccumulateBtn_Click" Width="Auto" Padding="6,4"/>
                        <TextBlock x:Name="AccumulateStatusText" Style="{StaticResource PanelLabelStyle}" Text="ON" Margin="8,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Stats Section -->
                    <Rectangle Height="1" Margin="0,12,0,12" Fill="#FFFFFFFF" Opacity="0.3"/>

                    <TextBlock x:Name="OverlayText"
                               Style="{StaticResource PanelLabelStyle}"
                               FontSize="11"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               LineHeight="15"/>

                    <!-- Keyboard Controls -->
                    <TextBlock Style="{StaticResource PanelHeaderStyle}" Text="CONTROLS"/>
                    <TextBlock Style="{StaticResource PanelLabelStyle}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap" LineHeight="14">
                        <Run Text="WASD: Move"/>
                        <LineBreak/>
                        <Run Text="LMB + Mouse: Look"/>
                        <LineBreak/>
                        <Run Text="M: acceleration-structure build mode (perf only, no visual change - see console)"/>
                        <LineBreak/>
                        <Run Text="F1: Toggle UI"/>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
